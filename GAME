<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>我的 2D Minecraft</title>
    <style>
        body { margin: 0; overflow: hidden; background: #87CEEB; font-family: Arial, sans-serif; }
        canvas { display: block; }
        #ui { position: absolute; top: 10px; left: 10px; background: rgba(0,0,0,0.5); color: white; padding: 10px; border-radius: 5px; pointer-events: none; }
    </style>
</head>
<body>

<div id="ui">
    控制：A, D 移動 / Space 跳躍<br>
    滑鼠左鍵：挖掘 / 右鍵：放土 (需點擊空白處)<br>
    狀態：<span id="status">遊戲運行中</span>
</div>
<canvas id="gameCanvas"></canvas>

<script>
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    // 遊戲參數
    const tileSize = 32;
    const gravity = 0.5;
    const world = []; // [x][y]
    const cols = Math.ceil(canvas.width / tileSize);
    const rows = Math.ceil(canvas.height / tileSize);

    // 玩家設定
    const player = {
        x: canvas.width / 2,
        y: 0,
        w: 24,
        h: 30,
        vx: 0,
        vy: 0,
        speed: 4,
        jumpPower: -10,
        grounded: false
    };

    // 1. 初始化地形
    function initWorld() {
        for (let x = 0; x < cols; x++) {
            world[x] = [];
            // 使用正弦波產生起伏山丘
            let groundLevel = Math.floor(rows / 2 + Math.sin(x * 0.2) * 4);
            for (let y = 0; y < rows; y++) {
                if (y > groundLevel + 1) world[x][y] = 3; // 石頭
                else if (y > groundLevel) world[x][y] = 2; // 泥土
                else if (y === groundLevel) world[x][y] = 1; // 草地
                else world[x][y] = 0; // 空氣
            }
        }
    }

    // 2. 鍵盤控制
    const keys = {};
    window.addEventListener('keydown', e => keys[e.code] = true);
    window.addEventListener('keyup', e => keys[e.code] = false);

    // 3. 滑鼠互動 (挖掘與建造)
    canvas.addEventListener('mousedown', e => {
        e.preventDefault();
        const rect = canvas.getBoundingClientRect();
        const mouseX = e.clientX - rect.left;
        const mouseY = e.clientY - rect.top;
        const gx = Math.floor(mouseX / tileSize);
        const gy = Math.floor(mouseY / tileSize);

        if (gx >= 0 && gx < cols && gy >= 0 && gy < rows) {
            if (e.button === 0) world[gx][gy] = 0; // 左鍵：挖掉
            if (e.button === 2) world[gx][gy] = 2; // 右鍵：放土
        }
    });
    canvas.oncontextmenu = () => false; // 禁用右鍵選單

    // 4. 碰撞檢查
    function checkCollision(x, y) {
        let gx = Math.floor(x / tileSize);
        let gy = Math.floor(y / tileSize);
        if (gx < 0 || gx >= cols || gy < 0 || gy >= rows) return false;
        return world[gx][gy] !== 0;
    }

    // 5. 更新邏輯
    function update() {
        // 玩家移動
        if (keys['KeyA']) player.vx = -player.speed;
        else if (keys['KeyD']) player.vx = player.speed;
        else player.vx = 0;

        if (keys['Space'] && player.grounded) {
            player.vy = player.jumpPower;
            player.grounded = false;
        }

        // 重力
        player.vy += gravity;
        player.x += player.vx;
        player.y += player.vy;

        // 簡易地板碰撞
        let gridX = Math.floor(player.x / tileSize);
        let gridY = Math.ceil((player.y + player.h) / tileSize);

        if (checkCollision(player.x + player.w/2, player.y + player.h)) {
            player.y = (gridY - 1) * tileSize - player.h;
            player.vy = 0;
            player.grounded = true;
        } else {
            player.grounded = false;
        }

        // 邊界限制
        if (player.x < 0) player.x = 0;
        if (player.x > canvas.width - player.w) player.x = canvas.width - player.w;
    }

    // 6. 繪製
    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // 繪製世界
        for (let x = 0; x < cols; x++) {
            for (let y = 0; y < rows; y++) {
                if (world[x][y] === 0) continue;
                
                if (world[x][y] === 1) ctx.fillStyle = '#4CAF50'; // 草
                else if (world[x][y] === 2) ctx.fillStyle = '#795548'; // 土
                else if (world[x][y] === 3) ctx.fillStyle = '#757575'; // 石
                
                ctx.fillRect(x * tileSize, y * tileSize, tileSize, tileSize);
            }
        }

        // 繪製玩家 (史蒂夫)
        ctx.fillStyle = '#2196F3';
        ctx.fillRect(player.x, player.y, player.w, player.h);
    }

    function gameLoop() {
        update();
        draw();
        requestAnimationFrame(gameLoop);
    }

    initWorld();
    gameLoop();
</script>
</body>
</html>
