└── script.js<!DOCTYPE html>
<html>
<head>
    <title>My 2D Minecraft</title>
    <style>
        body { margin: 0; overflow: hidden; background: #87CEEB; }
        canvas { display: block; background: #87CEEB; }
    </style>
</head>
<body>
<canvas id="gameCanvas"></canvas>

<script>
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const tileSize = 32;
    const world = []; // 儲存方塊的二維陣列

    // 1. 初始化地圖 (簡單地形生成)
    for (let x = 0; x < Math.ceil(canvas.width / tileSize); x++) {
        world[x] = [];
        let groundHeight = 10 + Math.floor(Math.sin(x * 0.2) * 3); // 簡單波浪地形
        for (let y = 0; y < Math.ceil(canvas.height / tileSize); y++) {
            if (y > groundHeight) world[x][y] = (y === groundHeight + 1) ? 1 : 2; // 1是草, 2是土
            else world[x][y] = 0; // 0是空氣
        }
    }

    // 2. 繪製函數
    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (let x = 0; x < world.length; x++) {
            for (let y = 0; y < world[x].length; y++) {
                if (world[x][y] === 1) ctx.fillStyle = '#45a049'; // 草地綠
                else if (world[x][y] === 2) ctx.fillStyle = '#795548'; // 泥土褐
                else continue;
                
                ctx.fillRect(x * tileSize, y * tileSize, tileSize, tileSize);
                ctx.strokeRect(x * tileSize, y * tileSize, tileSize, tileSize); // 畫出方塊線條
                ctx.strokeStyle = 'rgba(0,0,0,0.1)';
            }
        }
    }

    // 3. 互動：點擊挖掘
    canvas.addEventListener('mousedown', (e) => {
        const gridX = Math.floor(e.clientX / tileSize);
        const gridY = Math.floor(e.clientY / tileSize);
        if(world[gridX]) world[gridX][gridY] = 0; // 挖掉變成空氣
        draw();
    });

    draw();
</script>
</body>
</html>
